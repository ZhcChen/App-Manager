{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "App Manager",
  "version": "0.1.0",
  "identifier": "com.zhcchen.appmanager",
  "build": {
    "beforeBuildCommand": "pnpm build",
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:18420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "App Manager",
        "width": 1280,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
